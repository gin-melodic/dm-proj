# dm-proj backend deployment environment
# Copy to .env and replace every REQUIRED value before deployment.

# Public ports
SERVER_PORT=8080
RAG_PORT=8000
POSTGRES_PORT=5432
TZ=Asia/Shanghai

# Image names (the VPS offline bundle uses its own fixed :vps tags)
SERVER_IMAGE=dm-server:local
RAG_IMAGE=dm-knowledge-service:local

# PostgreSQL (REQUIRED: use a URL-safe password because it is embedded in a DSN)
POSTGRES_DB=dream_db
POSTGRES_USER=dream_user
POSTGRES_PASSWORD=

# RAG service
APP_ENV=production
API_DEBUG=false
RAG_LOG_LEVEL=INFO
KNOWLEDGE_BASE_DIR=data/knowledge_bases
KNOWLEDGE_CACHE_DB_PATH=data/knowledge.db
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=richinfoai/ritrieve_zh_v1
# Gemini embedding (used when EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_EMBEDDING_BATCH_SIZE=100
GEMINI_EMBEDDING_TIMEOUT_SECONDS=60
GEMINI_EMBEDDING_MAX_RETRIES=3
# LM Studio text embedding (used when EMBEDDING_PROVIDER=lmstudio)
# In Docker, host.docker.internal points to LM Studio running on the host.
LMSTUDIO_EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_EMBEDDING_MODEL=text-embedding-model
LMSTUDIO_EMBEDDING_API_KEY=
LMSTUDIO_EMBEDDING_DIMENSIONS=0
LMSTUDIO_EMBEDDING_BATCH_SIZE=32
LMSTUDIO_EMBEDDING_TIMEOUT_SECONDS=60
LMSTUDIO_EMBEDDING_MAX_RETRIES=3
ENABLE_JIEBA=true
ENABLE_SYNONYMS=true
SYNONYM_THRESHOLD=0.8
STRUCTURED_TEXT_BOOST=0.2
TXT_AI_WORKERS=1
MAX_FILE_SIZE_MB=50

# Go authentication (REQUIRED in production)
JWT_SECRET=
JWT_TIMEOUT=7200
WECHAT_APP_ID=
WECHAT_APP_SECRET=
SUPABASE_PROJECT_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# AI provider. Supported by dm-server: openrouter, qwen, hunyuan, groq, ollama, lmstudio
AI_SERVICE=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free
OPENROUTER_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-flash
QWEN_API_KEY=
HUNYUAN_BASE_URL=https://tokenhub.tencentmaas.com/v1
HUNYUAN_MODEL=deepseek-v4-flash
HUNYUAN_SECRET_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwq:32b
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=qwen3.6-27b-ud
